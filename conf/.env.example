# ResuMiner 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 监控配置
# ============================================
ENABLE_AUTO_MONITORING=1
AUTO_GENERATE_REPORT=1
MONITOR_LOG_LEVEL=INFO

# ============================================
# 爬虫平台配置
# ============================================
RUN_JOB51=1
RUN_BOSS=0
RUN_LIEPIN=1
RUN_LAGOU=0

# ============================================
# 爬取页数配置（全量）
# ============================================
JOB51_MAX_PAGES=500
BOSS_MAX_PAGES=1
LIEPIN_MAX_PAGES=500

# ============================================
# 关键词配置
# ============================================
JOB51_KEYWORD=实习
BOSS_KEYWORD=实习
LIEPIN_KEYWORD=实习

# ============================================
# 地域配置
# ============================================
JOB51_CITY=020000
BOSS_CITY=101020100
LIEPIN_CITY=020

# ============================================
# 数据过滤配置
# ============================================
TARGET_SCOPE_FILTER_ENABLED=0
TARGET_REQUIRE_ELITE=0
TARGET_KEEP_INFERRED_EDU=1
TARGET_KEEP_REVIEW_EDU=1

# ============================================
# 数据质量配置
# ============================================
MIN_FIELD_COMPLETENESS_RATE=80
MIN_JD_LENGTH=30

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# RPC 服务配置
# ============================================
RPC_HOST=localhost
RPC_PORT=5600
